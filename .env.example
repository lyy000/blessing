# 本地开发：可不配置，将自动使用项目下 data/bless.db
# Vercel / Netlify 线上：必须配置 Turso（或任意 libsql 远程地址 + 令牌）

# Turso 控制台复制的 Database URL（通常以 libsql:// 开头）
TURSO_DATABASE_URL=

# Turso 控制台创建的数据库 Token
TURSO_AUTH_TOKEN=

# 可选：与 TURSO_DATABASE_URL 二选一（若同时存在，优先使用 TURSO_DATABASE_URL）
# DATABASE_URL=

# --- 腾讯云轻量 / 自有服务器（见 DEPLOY.md 第七节）---
# 不配置 Turso 时，生产环境默认使用本机 SQLite（需持久磁盘）
# 建议把数据目录放在部署目录外，便于备份与重装：
# DATA_DIR=/var/lib/blessing
# NODE_ENV=production
# PORT=3000
# HOSTNAME=0.0.0.0
